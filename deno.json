{
  "name": "@cunarist/deno-dependency-check",
  "version": "0.3.2",
  "exports": {
    ".": "./src/mod.ts",
    "./lint": "./src/lint.ts"
  },
  "tasks": {
    "good": "deno run -A ./src/mod.ts examples/mod-a.ts",
    "bad": "deno run -A ./src/mod.ts examples/mod-b.ts",
    "test": "deno test -A"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.ns", "deno.unstable", "es2022"]
  },
  "lint": {
    "exclude": ["tests/fixture"],
    "plugins": [
      "jsr:@hugoalh/deno-lint-rules@0.8.3/recommended",
      "jsr:@ayk/lint-import-order@0.1.0",
      "./src/lint.ts"
    ],
    "rules": {
      "tags": ["recommended", "jsr"],
      "include": [
        "eqeqeq",
        "camelcase",
        "guard-for-in",
        "no-const-assign",
        "no-eval",
        "no-external-import",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-throw-literal",
        "prefer-ascii"
      ]
    }
  },
  "publish": {
    "exclude": ["examples", "tests"]
  },
  "imports": {
    "#lint": "./src/lint.ts",
    "#imports": "./src/imports.ts",
    "#paths": "./src/paths.ts",
    "@std/assert": "jsr:@std/assert@1"
  }
}
